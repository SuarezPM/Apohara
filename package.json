{
	"name": "apohara",
	"version": "2.0.0-alpha",
	"module": "index.ts",
	"type": "module",
	"main": "dist/cli.js",
	"bin": {
		"apohara": "./dist/cli.js"
	},
	"files": [
		"dist",
		"binaries",
		"scripts"
	],
	"optionalDependencies": {
		"@apohara/cli-darwin-x64": "0.1.0",
		"@apohara/cli-darwin-arm64": "0.1.0",
		"@apohara/cli-linux-x64": "0.1.0",
		"@apohara/cli-linux-arm64": "0.1.0",
		"@apohara/cli-win32-x64": "0.1.0"
	},
	"scripts": {
		"postinstall": "node scripts/postinstall.js",
		"build": "bun build src/cli.ts --target node --outdir dist",
		"start": "bun run src/cli.ts"
	},
	"engines": {
		"node": ">=22"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@types/bun": "latest",
		"vitest": "^4.1.5"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"commander": "^14.0.3",
		"zod": "^4.4.1"
	}
}

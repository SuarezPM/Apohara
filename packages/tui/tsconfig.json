{
	"compilerOptions": {
		"target": "ES2023",
		"module": "esnext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"allowImportingTsExtensions": true,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"types": ["bun-types"],
		"baseUrl": ".",
		"paths": {
			"../../src/core/*": ["../../src/core/*"],
			"../../../src/core/*": ["../../../src/core/*"]
		}
	},
	"include": ["./**/*"],
	"exclude": ["node_modules"]
}
